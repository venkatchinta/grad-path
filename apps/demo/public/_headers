# Security headers, applied by Cloudflare Pages / Netlify at the edge.
# The app is fully self-contained: no external scripts, fonts, or API calls.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  # Private beta: instruct search engines not to index, even via a direct link.
  # Remove this line at public launch (along with robots.txt Disallow).
  X-Robots-Tag: noindex, nofollow
